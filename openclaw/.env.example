# =============================================================================
# OpenClaw Docker 镜像配置文件
# 请修改以下配置后启动容器
# =============================================================================

# -----------------------------------------------------------------------------
# 基础配置
# -----------------------------------------------------------------------------
OPENCLAW_IMAGE=openclaw:local
OPENCLAW_CONFIG_DIR=./config
OPENCLAW_WORKSPACE_DIR=./workspace
OPENCLAW_GATEWAY_PORT=17654
OPENCLAW_BRIDGE_PORT=17655
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_TZ=Asia/Shanghai

# -----------------------------------------------------------------------------
# 网关认证 (重要: 请修改为强密码)
# -----------------------------------------------------------------------------
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
# 生成示例: openssl rand -hex 32

# -----------------------------------------------------------------------------
# AI 模型配置 (至少配置一个)
# -----------------------------------------------------------------------------
# Claude (推荐)
ANTHROPIC_API_KEY=sk-ant-...

# 或 OpenAI
# OPENAI_API_KEY=sk-...

# 或 Gemini
# GEMINI_API_KEY=...

# 阿里云百炼 Coding Plan (推荐国内用户使用)
# 获取地址: https://bailian.console.aliyun.com/cn-beijing/?tab=model#/efm/coding_plan
BAILIAN_API_KEY=sk-...

# -----------------------------------------------------------------------------
# 飞书(Lark/Feishu)配置
# -----------------------------------------------------------------------------
# 飞书开发者平台: https://open.feishu.cn/app
# Lark开发者平台: https://open.larksuite.com/app

FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_DOMAIN=feishu
FEISHU_CONNECTION_MODE=websocket

# -----------------------------------------------------------------------------
# 可选: 其他渠道配置
# -----------------------------------------------------------------------------
# Telegram
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...

# Discord
# DISCORD_BOT_TOKEN=...

# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
